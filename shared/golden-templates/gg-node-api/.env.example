PORT=3000
APP_NAME=gg-node-api
LOG_LEVEL=info
# PostgreSQL 16 — 없으면 데모 응답(L1). 값은 배포 시 secret 주입.
# DATABASE_URL=postgresql://appuser:CHANGE_ME@localhost:5432/gg_node_api
# 인증(승격 시): Keycloak OIDC — openid-client/jose로 위임, 직접 구현 금지
# OIDC_ISSUER=https://keycloak.internal/realms/gg
# OIDC_CLIENT_ID=gg-node-api
# OIDC_CLIENT_SECRET=CHANGE_ME
