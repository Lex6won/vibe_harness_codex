# 이 파일만 커밋한다. 실제 값이 든 .env 는 커밋 금지(.gitignore 처리).
# 실제 개인정보·비밀값 금지 — 개발·시험은 더미 값으로.

APP_NAME=gg-webapp
APP_BASE_PATH=/apps/gg-webapp
APP_ENV=dev

# PostgreSQL 16 — 값은 배포 시 podman secret/환경변수로 주입
DATABASE_URL=postgresql+psycopg://appuser:CHANGE_ME@localhost:5432/gg_webapp

# Keycloak OIDC (행정망 공용 인증) — 직접 구현 금지
OIDC_ISSUER=https://keycloak.internal/realms/gg
OIDC_CLIENT_ID=gg-webapp
OIDC_CLIENT_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME_RANDOM
